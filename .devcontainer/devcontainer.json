{
  "name": "claude-jail",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "claude-jail",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-python.python",
        "redhat.java",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}